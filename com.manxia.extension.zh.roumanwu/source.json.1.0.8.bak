{
  "metadata": {
    "id": "com.manxia.extension.zh.roumanwu",
    "name": "肉漫屋",
    "type": "manga",
    "version": "1.0.8",
    "language": "zh-TW",
    "baseUrl": "https://rouman5.com",
    "description": "肉漫屋 - 成人漫画网站（繁体中文），需要科学上网",
    "author": "ManXia Team (移植自 keiyoushi)",
    "nsfw": true,
    "tags": [
      "chinese",
      "nsfw",
      "adult"
    ],
    "Internet": false
  },
  "capabilities": {
    "urlResolver": true,
    "pagination": true,
    "errorRetry": true,
    "loginSupport": false
  },
  "network": {
    "userAgent": "Mozilla/5.0 (Linux; Android 13; Pixel 7) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Mobile Safari/537.36",
    "timeout": 30000,
    "retryCount": 3,
    "retryDelay": 2000,
    "rateLimit": 500,
    "headers": {}
  },
  "_MIRRORS": [
    "rouman5.com (主站)",
    "roum22.xyz (镜像)"
  ],
  "imageDescrambler": {
    "enabled": true,
    "algorithm": "roumanwu",
    "urlPattern": "sr:1",
    "blocks": "md5_last_byte_mod10_plus5",
    "outputQuality": 90
  },
  "searchConfig": {
    "types": [
      {
        "id": "search",
        "label": "關鍵字",
        "placeholder": "輸入漫畫名稱",
        "description": "搜尋漫畫",
        "isDefault": true
      }
    ]
  },
  "workflows": {
    "popular": {
      "description": "獲取熱門漫畫（首頁熱門區塊）",
      "supportsPagination": false,
      "actions": [
        {
          "type": "navigate",
          "url": "{{baseUrl}}/home",
          "timeout": 15000,
          "description": "導航到首頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 3000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "code": "(() => { const targetRegex = /正熱門|今日最佳|本週熱門/; const entries = []; const seen = new Set(); const sections = document.querySelectorAll('div.px-1 > div'); sections.forEach(section => { const header = section.querySelector(':scope > *:first-child'); if (!header || !targetRegex.test(header.textContent)) return; section.querySelectorAll('a[href*=\"/books/\"]').forEach(el => { const href = el.getAttribute('href') || ''; const m = href.match(/\\/books\\/([^/\\s?]+)/); if (!m) return; const slug = m[1]; if (seen.has(slug)) return; seen.add(slug); const titleEl = el.querySelector('div.truncate'); const title = titleEl ? titleEl.textContent.trim() : ''; const bgEl = el.querySelector('[style*=\"background-image\"]'); let cover = ''; if (bgEl) { const s = bgEl.getAttribute('style') || ''; const cm = s.match(/url\\(\\'([^']+)\\'\\)|url\\(\"([^\"]+)\"\\)|url\\(([^)]+)\\)/); cover = cm ? (cm[1] || cm[2] || cm[3] || '') : ''; } if (title && slug) entries.push({ id: slug, url: '/books/' + slug, title, cover, author: '', genre: '' }); }); }); return JSON.stringify(entries); })();",
          "description": "提取熱門區塊漫畫"
        }
      ]
    },
    "filter": {
      "description": "篩選漫畫（狀態：全部/連載中/已完結）",
      "supportsPagination": true,
      "defaults": {
        "continued": ""
      },
      "actions": [
        {
          "type": "navigate",
          "url": "{{baseUrl}}/books?page={{page}}{{#if continued}}&continued={{continued}}{{/if}}",
          "timeout": 15000,
          "description": "導航到篩選結果頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 3000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "code": "(() => { const entries = []; const seen = new Set(); document.querySelectorAll('a[href*=\"/books/\"]').forEach(el => { const href = el.getAttribute('href') || ''; const m = href.match(/\\/books\\/([^\\/\\s?]+)/); if (!m) return; const slug = m[1]; if (seen.has(slug)) return; seen.add(slug); const titleEl = el.querySelector('div.truncate'); const title = titleEl ? titleEl.textContent.trim() : ''; if (!title) return; const bgEl = el.querySelector('[style*=\"background-image\"]'); let cover = ''; if (bgEl) { const s = bgEl.getAttribute('style') || ''; const cm = s.match(/url\\('([^']+)'\\)|url\\(\"([^\"]+)\"\\)|url\\(([^)]+)\\)/); cover = cm ? (cm[1] || cm[2] || cm[3] || '') : ''; } entries.push({ id: slug, url: '/books/' + slug, title, cover, author: '', genre: '' }); }); return JSON.stringify(entries); })();",
          "description": "提取篩選結果漫畫列表"
        }
      ]
    },
    "latest": {
      "description": "獲取最新更新（首頁最近更新區塊）",
      "supportsPagination": false,
      "actions": [
        {
          "type": "navigate",
          "url": "{{baseUrl}}/home",
          "timeout": 15000,
          "description": "導航到首頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 3000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "code": "(() => { const entries = []; const seen = new Set(); const sections = document.querySelectorAll('div.px-1 > div'); sections.forEach(section => { const header = section.querySelector(':scope > *:first-child'); if (!header || !header.textContent.includes('最近更新')) return; section.querySelectorAll('a[href*=\"/books/\"]').forEach(el => { const href = el.getAttribute('href') || ''; const m = href.match(/\\/books\\/([^/\\s?]+)/); if (!m) return; const slug = m[1]; if (seen.has(slug)) return; seen.add(slug); const titleEl = el.querySelector('div.truncate'); const title = titleEl ? titleEl.textContent.trim() : ''; const bgEl = el.querySelector('[style*=\"background-image\"]'); let cover = ''; if (bgEl) { const s = bgEl.getAttribute('style') || ''; const cm = s.match(/url\\(\\'([^']+)\\'\\)|url\\(\"([^\"]+)\"\\)|url\\(([^)]+)\\)/); cover = cm ? (cm[1] || cm[2] || cm[3] || '') : ''; } if (title && slug) entries.push({ id: slug, url: '/books/' + slug, title, cover, author: '', genre: '' }); }); }); return JSON.stringify(entries); })();",
          "description": "提取最近更新區塊漫畫"
        }
      ]
    },
    "search": {
      "description": "搜尋漫畫（關鍵字，page 0-indexed）",
      "supportsPagination": true,
      "actions": [
        {
          "type": "script",
          "code": "(() => { const page = ({{page}} || 1) - 1; const term = encodeURIComponent('{{query}}'); return '{{baseUrl}}/search?term=' + term + '&page=' + page; })();",
          "description": "構建搜尋URL（page 從 0 開始）"
        },
        {
          "type": "navigate",
          "url": "{{scriptResult}}",
          "timeout": 15000,
          "description": "導航到搜尋結果頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 3000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "code": "(() => { const entries = []; const seen = new Set(); document.querySelectorAll('a[href*=\"/books/\"]').forEach(el => { const href = el.getAttribute('href') || ''; const m = href.match(/\\/books\\/([^\\/\\s?]+)/); if (!m) return; const slug = m[1]; if (seen.has(slug)) return; seen.add(slug); const titleEl = el.querySelector('div.truncate'); const title = titleEl ? titleEl.textContent.trim() : ''; if (!title) return; const bgEl = el.querySelector('[style*=\"background-image\"]'); let cover = ''; if (bgEl) { const s = bgEl.getAttribute('style') || ''; const cm = s.match(/url\\('([^']+)'\\)|url\\(\"([^\"]+)\"\\)|url\\(([^)]+)\\)/); cover = cm ? (cm[1] || cm[2] || cm[3] || '') : ''; } entries.push({ id: slug, url: '/books/' + slug, title, cover, author: '', genre: '' }); }); return JSON.stringify(entries); })();",
          "description": "提取搜尋結果漫畫列表"
        }
      ]
    },
    "getMangaDetail": {
      "description": "獲取漫畫詳情",
      "actions": [
        {
          "type": "script",
          "code": "(() => { const raw = String('{{mangaId}}' || '').trim(); let value = raw; try { if (/^https?:\\/\\//i.test(value)) { value = new URL(value).pathname || ''; } } catch (error) {} let match = value.match(/\\/books\\/([^\\/\\s?#]+)/); if (!match) match = value.match(/^books\\/([^\\/\\s?#]+)/); if (!match) match = value.match(/^([^\\/\\s?#]+)/); const slug = match ? match[1] : ''; if (!slug) { throw new Error('Roumanwu missing mangaId'); } return '{{baseUrl}}/books/' + slug; })();",
          "description": "規範化漫畫詳情頁 URL"
        },
        {
          "type": "navigate",
          "url": "{{scriptResult}}",
          "timeout": 15000,
          "description": "導航到漫畫詳情頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 5000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "code": "(() => { const clean = (value) => String(value || '').replace(/\\s+/g, ' ').trim(); const stripSiteSuffix = (value) => { const suffix = ' - 肉漫屋'; const text = clean(value); return text.endsWith(suffix) ? clean(text.slice(0, text.length - suffix.length)) : text; }; const getMeta = (name) => { const node = document.querySelector('meta[property=\"' + name + '\"]') || document.querySelector('meta[name=\"' + name + '\"]'); return node ? clean(node.getAttribute('content') || '') : ''; }; const pathMatch = (location.pathname || '').match(/\\/books\\/([^\\/\\s?#]+)/); const slug = pathMatch ? pathMatch[1] : ''; const infoBox = document.querySelector('div.basis-3\\\\/5'); const rows = infoBox ? Array.from(infoBox.children).map((el) => clean(el.textContent)) : []; const rowValue = (labels) => { for (const label of labels) { const row = rows.find((item) => item.startsWith(label)); if (row) { return clean(row.slice(label.length)); } } return ''; }; const bodyTextRaw = String(document.body ? document.body.innerText : ''); const bodyText = clean(bodyTextRaw); const bodyValue = (label) => { const match = bodyTextRaw.match(new RegExp(label + '\\\\s*[:：]\\\\s*([^\\\\n]+)')); return match ? clean(match[1]) : ''; }; const sanitizeTagText = (value) => { let text = clean(value); const cutMarkers = ['簡介', '開始閱讀', '放入書架']; cutMarkers.forEach((marker) => { const index = text.indexOf(marker); if (index >= 0) text = clean(text.slice(0, index)); }); return text; }; const coverCandidates = Array.from(document.querySelectorAll('img')).map((img) => ({ src: clean(img.getAttribute('src') || ''), alt: clean(img.getAttribute('alt') || '') })).filter((item) => item.src.length > 0 && !item.src.startsWith('/android-chrome-')); let title = rows.length > 0 ? rows[0] : ''; if (!title) title = stripSiteSuffix(getMeta('og:title')); if (!title) title = stripSiteSuffix(document.title); if (!title) { const coverImage = coverCandidates.find((item) => item.alt.toLowerCase().endsWith(' cover')); if (coverImage) title = clean(coverImage.alt.replace(/\\s*cover$/i, '')); } if (!title) title = bodyValue('別名'); let cover = ''; const infoImage = document.querySelector('div.basis-2\\\\/5 img'); if (infoImage) cover = clean(infoImage.getAttribute('src') || ''); if (!cover) cover = getMeta('og:image'); if (!cover && coverCandidates.length > 0) { const candidate = coverCandidates.find((item) => /cover/i.test(item.alt)) || coverCandidates[0]; cover = candidate ? candidate.src : ''; } let description = ''; const introNode = Array.from(document.querySelectorAll('p')).find((node) => clean(node.textContent).startsWith('簡介')); if (introNode) description = clean(introNode.textContent).replace(/^簡介[:：]/, '').trim(); if (!description) description = getMeta('og:description'); if (!description) { const descMatch = bodyText.match(/簡介\\s*[:：]\\s*([\\s\\S]*?)(?:\\s+放入書架\\s+開始閱讀|\\s+放入書架|\\s+開始閱讀|$)/); description = descMatch ? clean(descMatch[1]) : ''; } const author = rowValue(['作者:', '作者：']) || bodyValue('作者'); const statusText = rowValue(['狀態:', '狀態：']) || bodyValue('狀態'); const region = rowValue(['地區:', '地區：']) || bodyValue('地區'); const tagText = sanitizeTagText(rowValue(['標籤:', '標籤：']) || bodyValue('標籤')); const dateMatch = bodyText.match(/\\b\\d{1,2}\\/\\d{1,2}\\/\\d{4}\\b/); const tags = []; if (region) tags.push(region); if (tagText) tags.push(...tagText.split(/[、,，]/).map((item) => clean(item)).filter((item) => item.length > 0 && !/^[0-9./\\sKMkm]+$/.test(item))); const genre = Array.from(new Set(tags)).join(', '); return JSON.stringify({ id: slug, url: slug ? ('/books/' + slug) : '', title, cover, author, status: statusText.includes('完結') ? 'completed' : (statusText.includes('連載') ? 'ongoing' : 'unknown'), genre, description, updated: dateMatch ? dateMatch[0] : '' }); })();",
          "description": "提取漫畫詳情（標題/封面/作者/狀態/標籤/簡介/更新日期）"
        }
      ]
    },
    "getMangaDetailWithChapters": {
      "description": "获取漫画详情与章节列表（单次详情页导航）",
      "actions": [
        {
          "type": "script",
          "code": "(() => { const raw = String('{{mangaId}}' || '').trim(); let value = raw; try { if (/^https?:\\/\\//i.test(value)) { value = new URL(value).pathname || ''; } } catch (error) {} let match = value.match(/\\/books\\/([^\\/\\s?#]+)/); if (!match) match = value.match(/^books\\/([^\\/\\s?#]+)/); if (!match) match = value.match(/^([^\\/\\s?#]+)/); const slug = match ? match[1] : ''; if (!slug) { throw new Error('Roumanwu missing mangaId'); } return '{{baseUrl}}/books/' + slug; })();",
          "description": "規範化漫畫詳情頁 URL"
        },
        {
          "type": "navigate",
          "url": "{{scriptResult}}",
          "timeout": 15000,
          "description": "導航到漫畫詳情頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 5000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "description": "提取漫畫詳情（標題/封面/作者/狀態/標籤/簡介/更新日期）",
          "code": "(() => { const clean = (value) => String(value || '').replace(/\\s+/g, ' ').trim(); const stripSiteSuffix = (value) => { const suffix = ' - 肉漫屋'; const text = clean(value); return text.endsWith(suffix) ? clean(text.slice(0, text.length - suffix.length)) : text; }; const getMeta = (name) => { const node = document.querySelector('meta[property=\"' + name + '\"]') || document.querySelector('meta[name=\"' + name + '\"]'); return node ? clean(node.getAttribute('content') || '') : ''; }; const pathMatch = (location.pathname || '').match(/\\/books\\/([^\\/\\s?#]+)/); const slug = pathMatch ? pathMatch[1] : ''; const infoBox = document.querySelector('div.basis-3\\\\/5'); const rows = infoBox ? Array.from(infoBox.children).map((el) => clean(el.textContent)) : []; const rowValue = (labels) => { for (const label of labels) { const row = rows.find((item) => item.startsWith(label)); if (row) { return clean(row.slice(label.length)); } } return ''; }; const bodyTextRaw = String(document.body ? document.body.innerText : ''); const bodyText = clean(bodyTextRaw); const bodyValue = (label) => { const match = bodyTextRaw.match(new RegExp(label + '\\\\s*[:：]\\\\s*([^\\\\n]+)')); return match ? clean(match[1]) : ''; }; const sanitizeTagText = (value) => { let text = clean(value); const cutMarkers = ['簡介', '開始閱讀', '放入書架']; cutMarkers.forEach((marker) => { const index = text.indexOf(marker); if (index >= 0) text = clean(text.slice(0, index)); }); return text; }; const coverCandidates = Array.from(document.querySelectorAll('img')).map((img) => ({ src: clean(img.getAttribute('src') || ''), alt: clean(img.getAttribute('alt') || '') })).filter((item) => item.src.length > 0 && !item.src.startsWith('/android-chrome-')); let title = rows.length > 0 ? rows[0] : ''; if (!title) title = stripSiteSuffix(getMeta('og:title')); if (!title) title = stripSiteSuffix(document.title); if (!title) { const coverImage = coverCandidates.find((item) => item.alt.toLowerCase().endsWith(' cover')); if (coverImage) title = clean(coverImage.alt.replace(/\\s*cover$/i, '')); } if (!title) title = bodyValue('別名'); let cover = ''; const infoImage = document.querySelector('div.basis-2\\\\/5 img'); if (infoImage) cover = clean(infoImage.getAttribute('src') || ''); if (!cover) cover = getMeta('og:image'); if (!cover && coverCandidates.length > 0) { const candidate = coverCandidates.find((item) => /cover/i.test(item.alt)) || coverCandidates[0]; cover = candidate ? candidate.src : ''; } let description = ''; const introNode = Array.from(document.querySelectorAll('p')).find((node) => clean(node.textContent).startsWith('簡介')); if (introNode) description = clean(introNode.textContent).replace(/^簡介[:：]/, '').trim(); if (!description) description = getMeta('og:description'); if (!description) { const descMatch = bodyText.match(/簡介\\s*[:：]\\s*([\\s\\S]*?)(?:\\s+放入書架\\s+開始閱讀|\\s+放入書架|\\s+開始閱讀|$)/); description = descMatch ? clean(descMatch[1]) : ''; } const author = rowValue(['作者:', '作者：']) || bodyValue('作者'); const statusText = rowValue(['狀態:', '狀態：']) || bodyValue('狀態'); const region = rowValue(['地區:', '地區：']) || bodyValue('地區'); const tagText = sanitizeTagText(rowValue(['標籤:', '標籤：']) || bodyValue('標籤')); const dateMatch = bodyText.match(/\\b\\d{1,2}\\/\\d{1,2}\\/\\d{4}\\b/); const tags = []; if (region) tags.push(region); if (tagText) tags.push(...tagText.split(/[、,，]/).map((item) => clean(item)).filter((item) => item.length > 0 && !/^[0-9./\\sKMkm]+$/.test(item))); const genre = Array.from(new Set(tags)).join(', '); return JSON.stringify({ id: slug, url: slug ? ('/books/' + slug) : '', title, cover, author, status: statusText.includes('完結') ? 'completed' : (statusText.includes('連載') ? 'ongoing' : 'unknown'), genre, description, updated: dateMatch ? dateMatch[0] : '' }); })();"
        },
        {
          "type": "script",
          "description": "提取章節列表（與詳情頁共用同一次導航）",
          "code": "(() => {\n  const clean = (value) => String(value || '').replace(/\\s+/g, ' ').trim();\n  const decodeHtml = (value) => {\n    const node = document.createElement('textarea');\n    node.innerHTML = String(value || '');\n    return clean(node.value);\n  };\n  const normalizeTitle = (value) => {\n    const title = clean(value);\n    const duplicateMatch = title.match(/^(.+)\\s+\\1$/);\n    return duplicateMatch ? clean(duplicateMatch[1]) : title;\n  };\n  const pathMatch = (location.pathname || '').match(/\\/books\\/([^\\/\\s?#]+)/);\n  const currentSlug = pathMatch ? pathMatch[1] : '';\n  const requestUrl = currentSlug ? ('{{baseUrl}}/books/' + currentSlug) : '';\n  const rows = Array.from(document.querySelector('div.basis-3\\\\/5')?.children || []).map((el) => clean(el.textContent));\n  const bodyTextRaw = String(document.body ? document.body.innerText : '');\n  const bodyText = clean(bodyTextRaw);\n  let updateTime = '';\n  for (let i = rows.length - 1; i >= 0; i--) {\n    const match = rows[i].match(/\\b(\\d{1,2}\\/\\d{1,2}\\/\\d{4})\\b/);\n    if (match) {\n      updateTime = match[1];\n      break;\n    }\n  }\n  if (!updateTime) {\n    const bodyMatch = bodyText.match(/\\b(\\d{1,2}\\/\\d{1,2}\\/\\d{4})\\b/);\n    updateTime = bodyMatch ? bodyMatch[1] : '';\n  }\n  const chapterMap = new Map();\n  const hasRealTitle = (value) => {\n    const title = clean(value);\n    return title.length > 0 && (/\\d/.test(title) || title.length > 4);\n  };\n  const putChapter = (slug, numberText, rawTitle) => {\n    const normalizedSlug = clean(slug);\n    const normalizedNumber = clean(numberText);\n    if (!normalizedSlug || !normalizedNumber) {\n      return;\n    }\n    const key = normalizedSlug + '/' + normalizedNumber;\n    const number = Number(normalizedNumber);\n    const fallbackTitle = Number.isNaN(number) ? ('Episode ' + normalizedNumber) : ('Episode ' + String(number + 1));\n    const normalizedTitle = normalizeTitle(rawTitle);\n    const titleIsReal = hasRealTitle(normalizedTitle);\n    const title = titleIsReal ? normalizedTitle : fallbackTitle;\n    const existing = chapterMap.get(key);\n    if (!existing || (!existing.hasRealTitle && titleIsReal)) {\n      chapterMap.set(key, {\n        id: key,\n        url: '/books/' + key,\n        title,\n        updateTime,\n        hasRealTitle: titleIsReal\n      });\n    }\n  };\n  const escapeRegExp = (value) => String(value || '').replace(/[\\\\^$.*+?()[\\]{}|]/g, '\\\\$&');\n  const parseText = (text) => {\n    const normalizedText = String(text || '').replace(/\\\\u002F/g, '/').replace(/\\\\\\//g, '/').replace(/&amp;/g, '&');\n    if (!currentSlug || normalizedText.length === 0) {\n      return;\n    }\n    const escapedSlug = escapeRegExp(currentSlug);\n    const anchorRegex = new RegExp(\"<a[^>]+href=[\\\\\\\"']([^\\\\\\\"']*\\\\/books\\\\/\" + escapedSlug + \"\\\\/(\\\\d+)(?:[?#][^\\\\\\\"']*)?)[\\\\\\\"'][^>]*>([\\\\s\\\\S]*?)<\\\\/a>\", 'gi');\n    let anchorMatch = anchorRegex.exec(normalizedText);\n    while (anchorMatch !== null) {\n      const anchorText = decodeHtml(String(anchorMatch[3] || '').replace(/<[^>]+>/g, ' '));\n      putChapter(currentSlug, anchorMatch[2], anchorText);\n      anchorMatch = anchorRegex.exec(normalizedText);\n    }\n    const hrefRegex = new RegExp(\"\\\\/books\\\\/\" + escapedSlug + \"\\\\/(\\\\d+)(?=[\\\\\\\"'#?<\\\\s])\", 'g');\n    let hrefMatch = hrefRegex.exec(normalizedText);\n    while (hrefMatch !== null) {\n      putChapter(currentSlug, hrefMatch[1], '');\n      hrefMatch = hrefRegex.exec(normalizedText);\n    }\n  };\n  const fetchText = (rsc) => {\n    if (!requestUrl) {\n      return '';\n    }\n    const xhr = new XMLHttpRequest();\n    xhr.open('GET', requestUrl, false);\n    xhr.setRequestHeader('cache-control', 'no-store');\n    if (rsc) {\n      xhr.setRequestHeader('rsc', '1');\n    }\n    try {\n      xhr.send(null);\n      if (xhr.status >= 200 && xhr.status < 400) {\n        return String(xhr.responseText || '');\n      }\n    } catch (error) {}\n    return '';\n  };\n  document.querySelectorAll('a[href*=\\\"/books/\\\"]').forEach((anchor) => {\n    const href = clean(anchor.getAttribute('href') || '');\n    const match = href.match(/\\/books\\/([^\\/\\s?#]+)\\/(\\d+)(?:[?#].*)?$/);\n    if (match) {\n      putChapter(match[1], match[2], clean(anchor.textContent));\n    }\n  });\n  const html = document.documentElement ? document.documentElement.innerHTML : '';\n  parseText(html);\n  if (chapterMap.size <= 1) {\n    parseText(fetchText(false));\n    parseText(fetchText(true));\n  }\n  if (chapterMap.size === 0 && currentSlug) {\n    putChapter(currentSlug, '0', '');\n  }\n  const chapters = Array.from(chapterMap.values())\n    .sort((left, right) => Number(left.id.split('/').pop() || '0') - Number(right.id.split('/').pop() || '0'))\n    .map((item) => ({ id: item.id, url: item.url, title: item.title, updateTime: item.updateTime }));\n  return JSON.stringify(chapters);\n})();"
        }
      ]
    },
    "getChapterList": {
      "description": "獲取章節列表",
      "actions": [
        {
          "type": "script",
          "code": "(() => { const raw = String('{{mangaId}}' || '').trim(); let value = raw; try { if (/^https?:\\/\\//i.test(value)) { value = new URL(value).pathname || ''; } } catch (error) {} let match = value.match(/\\/books\\/([^\\/\\s?#]+)/); if (!match) match = value.match(/^books\\/([^\\/\\s?#]+)/); if (!match) match = value.match(/^([^\\/\\s?#]+)/); const slug = match ? match[1] : ''; if (!slug) { throw new Error('Roumanwu missing mangaId'); } return '{{baseUrl}}/books/' + slug; })();",
          "description": "規範化漫畫詳情頁 URL"
        },
        {
          "type": "navigate",
          "url": "{{scriptResult}}",
          "timeout": 15000,
          "description": "導航到漫畫詳情頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 5000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "code": "(() => {\n  const clean = (value) => String(value || '').replace(/\\s+/g, ' ').trim();\n  const decodeHtml = (value) => {\n    const node = document.createElement('textarea');\n    node.innerHTML = String(value || '');\n    return clean(node.value);\n  };\n  const normalizeTitle = (value) => {\n    const title = clean(value);\n    const duplicateMatch = title.match(/^(.+)\\s+\\1$/);\n    return duplicateMatch ? clean(duplicateMatch[1]) : title;\n  };\n  const pathMatch = (location.pathname || '').match(/\\/books\\/([^\\/\\s?#]+)/);\n  const currentSlug = pathMatch ? pathMatch[1] : '';\n  const requestUrl = currentSlug ? ('{{baseUrl}}/books/' + currentSlug) : '';\n  const rows = Array.from(document.querySelector('div.basis-3\\\\/5')?.children || []).map((el) => clean(el.textContent));\n  const bodyTextRaw = String(document.body ? document.body.innerText : '');\n  const bodyText = clean(bodyTextRaw);\n  let updateTime = '';\n  for (let i = rows.length - 1; i >= 0; i--) {\n    const match = rows[i].match(/\\b(\\d{1,2}\\/\\d{1,2}\\/\\d{4})\\b/);\n    if (match) {\n      updateTime = match[1];\n      break;\n    }\n  }\n  if (!updateTime) {\n    const bodyMatch = bodyText.match(/\\b(\\d{1,2}\\/\\d{1,2}\\/\\d{4})\\b/);\n    updateTime = bodyMatch ? bodyMatch[1] : '';\n  }\n  const chapterMap = new Map();\n  const hasRealTitle = (value) => {\n    const title = clean(value);\n    return title.length > 0 && (/\\d/.test(title) || title.length > 4);\n  };\n  const putChapter = (slug, numberText, rawTitle) => {\n    const normalizedSlug = clean(slug);\n    const normalizedNumber = clean(numberText);\n    if (!normalizedSlug || !normalizedNumber) {\n      return;\n    }\n    const key = normalizedSlug + '/' + normalizedNumber;\n    const number = Number(normalizedNumber);\n    const fallbackTitle = Number.isNaN(number) ? ('Episode ' + normalizedNumber) : ('Episode ' + String(number + 1));\n    const normalizedTitle = normalizeTitle(rawTitle);\n    const titleIsReal = hasRealTitle(normalizedTitle);\n    const title = titleIsReal ? normalizedTitle : fallbackTitle;\n    const existing = chapterMap.get(key);\n    if (!existing || (!existing.hasRealTitle && titleIsReal)) {\n      chapterMap.set(key, {\n        id: key,\n        url: '/books/' + key,\n        title,\n        updateTime,\n        hasRealTitle: titleIsReal\n      });\n    }\n  };\n  const escapeRegExp = (value) => String(value || '').replace(/[\\\\^$.*+?()[\\]{}|]/g, '\\\\$&');\n  const parseText = (text) => {\n    const normalizedText = String(text || '').replace(/\\\\u002F/g, '/').replace(/\\\\\\//g, '/').replace(/&amp;/g, '&');\n    if (!currentSlug || normalizedText.length === 0) {\n      return;\n    }\n    const escapedSlug = escapeRegExp(currentSlug);\n    const anchorRegex = new RegExp(\"<a[^>]+href=[\\\\\\\"']([^\\\\\\\"']*\\\\/books\\\\/\" + escapedSlug + \"\\\\/(\\\\d+)(?:[?#][^\\\\\\\"']*)?)[\\\\\\\"'][^>]*>([\\\\s\\\\S]*?)<\\\\/a>\", 'gi');\n    let anchorMatch = anchorRegex.exec(normalizedText);\n    while (anchorMatch !== null) {\n      const anchorText = decodeHtml(String(anchorMatch[3] || '').replace(/<[^>]+>/g, ' '));\n      putChapter(currentSlug, anchorMatch[2], anchorText);\n      anchorMatch = anchorRegex.exec(normalizedText);\n    }\n    const hrefRegex = new RegExp(\"\\\\/books\\\\/\" + escapedSlug + \"\\\\/(\\\\d+)(?=[\\\\\\\"'#?<\\\\s])\", 'g');\n    let hrefMatch = hrefRegex.exec(normalizedText);\n    while (hrefMatch !== null) {\n      putChapter(currentSlug, hrefMatch[1], '');\n      hrefMatch = hrefRegex.exec(normalizedText);\n    }\n  };\n  const fetchText = (rsc) => {\n    if (!requestUrl) {\n      return '';\n    }\n    const xhr = new XMLHttpRequest();\n    xhr.open('GET', requestUrl, false);\n    xhr.setRequestHeader('cache-control', 'no-store');\n    if (rsc) {\n      xhr.setRequestHeader('rsc', '1');\n    }\n    try {\n      xhr.send(null);\n      if (xhr.status >= 200 && xhr.status < 400) {\n        return String(xhr.responseText || '');\n      }\n    } catch (error) {}\n    return '';\n  };\n  document.querySelectorAll('a[href*=\\\"/books/\\\"]').forEach((anchor) => {\n    const href = clean(anchor.getAttribute('href') || '');\n    const match = href.match(/\\/books\\/([^\\/\\s?#]+)\\/(\\d+)(?:[?#].*)?$/);\n    if (match) {\n      putChapter(match[1], match[2], clean(anchor.textContent));\n    }\n  });\n  const html = document.documentElement ? document.documentElement.innerHTML : '';\n  parseText(html);\n  if (chapterMap.size <= 1) {\n    parseText(fetchText(false));\n    parseText(fetchText(true));\n  }\n  if (chapterMap.size === 0 && currentSlug) {\n    putChapter(currentSlug, '0', '');\n  }\n  const chapters = Array.from(chapterMap.values())\n    .sort((left, right) => Number(left.id.split('/').pop() || '0') - Number(right.id.split('/').pop() || '0'))\n    .map((item) => ({ id: item.id, url: item.url, title: item.title, updateTime: item.updateTime }));\n  return JSON.stringify(chapters);\n})();",
          "description": "提取章節列表（去重開始閱讀入口，chapterId=slug/num）"
        }
      ]
    },
    "getPageList": {
      "description": "获取章节图片列表（导航到章节页后直接提取页面图片）",
      "actions": [
        {
          "type": "script",
          "code": "(() => {\n  let chapter = String('{{chapterId}}' || '').trim();\n  if (!chapter) {\n    return JSON.stringify([]);\n  }\n  if (chapter.startsWith('http')) {\n    try {\n      chapter = new URL(chapter).pathname || '';\n    } catch (error) {}\n  }\n  chapter = chapter.replace(/^\\/+/, '');\n  if (chapter.startsWith('books/')) {\n    chapter = chapter.replace(/^books\\//, '');\n  }\n  if (!chapter) {\n    return JSON.stringify([]);\n  }\n  return '{{baseUrl}}/books/' + chapter;\n})();",
          "description": "規範化章節頁 URL"
        },
        {
          "type": "navigate",
          "url": "{{scriptResult}}",
          "timeout": 15000,
          "description": "導航到章節頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 2500,
          "description": "等待章節頁載入"
        },
        {
          "type": "script",
          "code": "(() => {\n  const seen = new Set();\n  const pages = [];\n  const normalizeUrl = (raw) => {\n    let url = String(raw || '').trim();\n    if (!url) {\n      return '';\n    }\n    url = url.replace(/\\\\u002F/g, '/').replace(/\\\\\\//g, '/').replace(/&amp;/g, '&');\n    if (url.startsWith('//')) {\n      url = 'https:' + url;\n    }\n    if (url.startsWith('/')) {\n      try {\n        url = new URL(url, location.origin || '{{baseUrl}}').toString();\n      } catch (error) {\n        return '';\n      }\n    }\n    if (!/^https?:\\/\\//i.test(url)) {\n      return '';\n    }\n    const isCdnImage = url.includes('rmcdn');\n    const hasImageExtension = /\\.(jpg|jpeg|png|webp|gif)(?:[?#].*)?$/i.test(url);\n    if (!isCdnImage && !hasImageExtension) {\n      return '';\n    }\n    if (/\\/loading\\.jpg(?:[?#].*)?$/i.test(url)) {\n      return '';\n    }\n    return url;\n  };\n  const pushUrl = (raw) => {\n    const url = normalizeUrl(raw);\n    if (!url || seen.has(url)) {\n      return;\n    }\n    seen.add(url);\n    pages.push({ index: pages.length, url });\n  };\n  const html = document.documentElement ? document.documentElement.outerHTML : '';\n  const patterns = [/\\\\\\\"imageUrl\\\\\\\":\\\\\\\"([^\\\\\\\"]+)\\\\\\\"/g, /\\\"imageUrl\\\":\\\"([^\\\"]+)\\\"/g];\n  patterns.forEach((pattern) => {\n    let match = pattern.exec(html);\n    while (match !== null) {\n      pushUrl(match[1]);\n      match = pattern.exec(html);\n    }\n  });\n  if (pages.length === 0) {\n    document.querySelectorAll('img').forEach((img) => {\n      pushUrl(img.getAttribute('src') || '');\n      pushUrl(img.getAttribute('data-src') || '');\n      pushUrl(img.currentSrc || '');\n    });\n  }\n  if (pages.length === 0) {\n    document.querySelectorAll('link[rel=\\\"preload\\\"][as=\\\"image\\\"]').forEach((link) => {\n      pushUrl(link.getAttribute('href') || '');\n    });\n  }\n  return JSON.stringify(pages);\n})();",
          "description": "從當前章節頁 HTML / DOM 提取圖片列表"
        }
      ]
    },
    "getImageUrl": {
      "description": "获取图片URL（直接返回）",
      "actions": [
        {
          "type": "script",
          "code": "(() => { return '{{imageUrl}}'; })();",
          "description": "返回图片URL"
        }
      ]
    },
    "directSearch": {
      "description": "直達搜尋（輸入 slug 或 /books/ 連結）",
      "actions": [
        {
          "type": "script",
          "code": "(() => { const q = ('{{query}}' || '').trim(); let slug = q; const m1 = q.match(/\\/books\\/([^\\/\\s?#]+)/); if (m1) slug = m1[1]; const m2 = q.match(/^books\\/([^\\/\\s?#]+)/); if (m2) slug = m2[1]; try { if (/^https?:\\/\\//i.test(q)) { const u = new URL(q); const m3 = (u.pathname || '').match(/\\/books\\/([^\\/\\s?#]+)/); if (m3) slug = m3[1]; } } catch (e) {} const result = { type: 'detail', manga: { id: slug, title: '', url: '/books/' + slug, cover: '' }, error: null }; return JSON.stringify(result); })();",
          "description": "解析 slug 並返回 detail（後續由 getMangaDetail 處理）"
        }
      ]
    },
    "searchByTag": {
      "description": "按標籤搜尋漫畫（複用 /search?term= ，page 0-indexed）",
      "supportsPagination": true,
      "actions": [
        {
          "type": "script",
          "code": "(() => { const page = ({{page}} || 1) - 1; const term = encodeURIComponent('{{tagId}}'); return '{{baseUrl}}/search?term=' + term + '&page=' + page; })();",
          "description": "構建標籤搜尋URL"
        },
        {
          "type": "navigate",
          "url": "{{scriptResult}}",
          "timeout": 15000,
          "description": "導航到標籤搜尋結果頁"
        },
        {
          "type": "wait",
          "condition": "time",
          "duration": 3000,
          "description": "等待頁面載入"
        },
        {
          "type": "script",
          "code": "(() => { const entries = []; const seen = new Set(); document.querySelectorAll('a[href*=\"/books/\"]').forEach(el => { const href = el.getAttribute('href') || ''; const m = href.match(/\\/books\\/([^\\/\\s?]+)/); if (!m) return; const slug = m[1]; if (seen.has(slug)) return; seen.add(slug); const titleEl = el.querySelector('div.truncate'); const title = titleEl ? titleEl.textContent.trim() : ''; if (!title) return; const bgEl = el.querySelector('[style*=\"background-image\"]'); let cover = ''; if (bgEl) { const s = bgEl.getAttribute('style') || ''; const cm = s.match(/url\\('([^']+)'\\)|url\\(\"([^\"]+)\"\\)|url\\(([^)]+)\\)/); cover = cm ? (cm[1] || cm[2] || cm[3] || '') : ''; } entries.push({ id: slug, url: '/books/' + slug, title, cover, author: '', genre: '' }); }); return JSON.stringify(entries); })();",
          "description": "提取標籤搜尋結果漫畫列表"
        }
      ]
    }
  },
  "tabs": [
    {
      "id": "popular",
      "type": "popular",
      "name": "熱門",
      "enabled": true,
      "order": 0,
      "requiresLogin": false
    },
    {
      "id": "latest",
      "type": "latest",
      "name": "最新",
      "enabled": true,
      "order": 1,
