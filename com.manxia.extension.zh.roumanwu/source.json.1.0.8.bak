    }
  },
  "changelog": [
    {
      "version": "1.0.8",
      "date": "2026-04-29",
      "changes": [
        "修复 ArkWeb 详情页只渲染“开始阅读”入口时，章节列表只返回 1 章的问题",
        "章节提取在 DOM/HTML 命中不足时，同步请求详情页 HTML 与 RSC 数据兜底解析完整章节链接"
      ]
    },
    {
      "version": "1.0.7",
      "date": "2026-04-29",
      "changes": [
        "根据站点实测 DOM，详情页选择器仍有效",
        "延长详情与章节工作流等待时间，降低 ArkWeb 慢加载时脚本过早执行导致空详情的概率"
      ]
    },
    {
      "version": "1.0.6",
      "date": "2026-04-03",
      "changes": [
        "修复章节列表在真机详情页只命中“开始阅读”入口时，漏抓后续章节的问题",
        "getChapterList 与合并详情工作流改为同时扫描 DOM 与原始 HTML，统一去重并保留真实章节标题",
        "getPageList 改回导航到章节页后直接从当前页面 HTML / DOM 提取 imageUrl，避免同步 XHR 在 ArkWeb 注入脚本里返回空值"
      ]
    },
    {
      "version": "1.0.5",
      "date": "2026-04-03",
      "changes": [
        "修复详情页、合并详情页、章节列表对 mangaId 传参形态的兼容问题",
        "统一先规范化裸 slug、/books/slug 与完整 URL，再导航到详情页，避免真机详情页落到错误地址"
      ]
    },
    {
      "version": "1.0.4",
      "date": "2026-04-02",
      "changes": [
        "新增 getMangaDetailWithChapters，與同類 WebView 圖源保持一致，詳情與章節共用同一次導航",
        "減少詳情階段對共享 WebView 的重複切頁，降低與後台預取流程互相干擾的機率"
      ]
    },
    {
      "version": "1.0.3",
      "date": "2026-04-02",
      "changes": [
        "将 getPageList 改为单次同步 XHR 直接请求章节页，移除 navigate + wait 对共享页面状态的依赖",
        "修复详情页推荐搜索与阅读页并行时，肉漫屋在 46% 卡住的问题"
      ]
    },
    {
      "version": "1.0.2",
      "date": "2026-04-02",
      "changes": [
        "修复 getPageList 与详情页后台推荐搜索共享 WebView 时互相抢占的问题",
        "改为先导航到章节页，再通过同源同步 XHR 提取 RSC imageUrl，失败时回退 DOM 图片节点"
      ]
    },
    {
      "version": "1.0.1",
      "date": "2026-04-02",
      "changes": [
        "修复详情页与章节页对裸 slug 的兼容",
        "修复阅读页 getPageList，改为同步 XHR 提取 RSC 图片列表，避免异步脚本结果丢失"
      ]
    },
    {
      "version": "1.0.0",
      "date": "2026-02-25",
      "changes": [
        "初始版本，從 Kotlin 移植至 ManXia JSON 格式",
        "支持熱門、最新、搜尋、篩選（連載狀態）功能",
        "支持漫畫詳情與章節列表（根據 /books/{slug}/{num} 解析）",
        "支持圖片列表（RSC XHR + imageUrl 正規對比）",
        "支持圖片解擾演算法（roumanwu / md5_last_byte_mod10_plus5）",
        "分頁均為 0-indexed（/search?page=0, /books?page=0）"
      ]
    }
  ]
}
